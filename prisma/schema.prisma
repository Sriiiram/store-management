generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./store.db"
}

// ─── Product Catalog ───────────────────────────────────────────────────────────

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  parentId  Int?
  parent    Category? @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              Int              @id @default(autoincrement())
  sku             String           @unique
  name            String
  brand           String?
  categoryId      Int
  category        Category         @relation(fields: [categoryId], references: [id])
  hsnCode         String?
  unit            String           @default("PCS")
  gstRate         Float            @default(18)
  description     String?
  imageUrl        String?
  
  // Price fields (stored centrally for quick access)
  costPrice       Float            @default(0)
  mrp             Float            @default(0)
  sellingPriceGst Float            @default(0)
  sellingPriceCash Float           @default(0)
  minMarginPct    Float            @default(10)
  
  // Stock thresholds
  reorderLevel    Int              @default(5)
  maxStock        Int              @default(100)
  
  // Relations
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  supplierId      Int?
  knowledge       ProductKnowledge?
  inventory       InventoryItem[]
  saleItems       SaleItem[]
  priceHistory    PriceHistory[]
  stockMovements  StockMovement[]
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([name])
  @@index([categoryId])
  @@index([brand])
}

// ─── Product Knowledge Base ────────────────────────────────────────────────────

model ProductKnowledge {
  id              Int      @id @default(autoincrement())
  productId       Int      @unique
  product         Product  @relation(fields: [productId], references: [id])
  
  whatItDoes      String?  // What the product can do
  whatItCantDo    String?  // Limitations
  bestFor         String?  // Ideal use cases
  notSuitableFor  String?  // Anti-use cases
  keySpecs        String?  // Key specifications as text
  commonQuestions String?  // FAQ-style Q&A (JSON string)
  accessories     String?  // What else customer needs
  alternatives    String?  // Compared to other products
  proTips         String?  // Expert sales tips
  
  updatedAt       DateTime @updatedAt
}

// ─── Inventory & Locations ─────────────────────────────────────────────────────

model Godown {
  id          Int        @id @default(autoincrement())
  name        String
  address     String?
  locations   Location[]
  createdAt   DateTime   @default(now())
}

model Location {
  id          Int             @id @default(autoincrement())
  code        String          @unique // e.g., "GD1-R2-S3"
  godownId    Int
  godown      Godown          @relation(fields: [godownId], references: [id])
  rack        String?
  shelf       String?
  zone        String?
  description String?
  inventory   InventoryItem[]
  createdAt   DateTime        @default(now())

  @@index([godownId])
}

model InventoryItem {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  locationId  Int
  location    Location @relation(fields: [locationId], references: [id])
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([productId, locationId])
  @@index([productId])
  @@index([locationId])
}

model StockMovement {
  id          Int      @id @default(autoincrement())
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  type        String   // "IN" | "OUT" | "TRANSFER" | "ADJUSTMENT"
  quantity    Int
  fromLocation String?
  toLocation  String?
  reference   String?  // Purchase bill no, sale id, etc.
  notes       String?
  createdAt   DateTime @default(now())

  @@index([productId])
  @@index([type])
  @@index([createdAt])
}

// ─── Suppliers ─────────────────────────────────────────────────────────────────

model Supplier {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String?
  gstin     String?
  address   String?
  products  Product[]
  createdAt DateTime  @default(now())
}

// ─── Sales & Billing ───────────────────────────────────────────────────────────

model Sale {
  id            Int        @id @default(autoincrement())
  invoiceNo     String?    @unique // null for non-billed sales
  type          String     // "GST" | "CASH" (billed vs non-billed)
  customerName  String?
  customerPhone String?
  customerGstin String?
  
  subtotal      Float      @default(0)
  gstAmount     Float      @default(0)
  discount      Float      @default(0)
  totalAmount   Float      @default(0)
  
  paymentMode   String     @default("CASH") // "CASH" | "UPI" | "CARD" | "CREDIT"
  notes         String?
  
  items         SaleItem[]
  createdAt     DateTime   @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([customerPhone])
}

model SaleItem {
  id          Int     @id @default(autoincrement())
  saleId      Int
  sale        Sale    @relation(fields: [saleId], references: [id])
  productId   Int
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  gstRate     Float   @default(0)
  gstAmount   Float   @default(0)
  total       Float

  @@index([saleId])
  @@index([productId])
}

// ─── Price History (audit trail) ───────────────────────────────────────────────

model PriceHistory {
  id              Int      @id @default(autoincrement())
  productId       Int
  product         Product  @relation(fields: [productId], references: [id])
  field           String   // "costPrice" | "sellingPriceGst" | "sellingPriceCash" | "mrp"
  oldValue        Float
  newValue        Float
  changedAt       DateTime @default(now())

  @@index([productId])
  @@index([changedAt])
}
